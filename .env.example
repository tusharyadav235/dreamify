# ─────────────────────────────────────────────────────────────
#  Dreamify — Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_this_root_password
DB_NAME=dreamify
DB_USER=dreamify_user
DB_PASSWORD=change_this_db_password

# ── App ───────────────────────────────────────────────────────
# Your EC2 public IP or domain (used for CORS reference)
APP_DOMAIN=http://your-ec2-ip
